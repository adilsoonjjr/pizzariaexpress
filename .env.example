# ──────────────────────────────────────────────────────────────
# PizzaExpress — variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores
# IMPORTANTE: Nunca use prefixo VITE_ nestas variáveis — elas
# ficam apenas no servidor (Vercel Functions), nunca no browser.
# ──────────────────────────────────────────────────────────────

# Neon PostgreSQL — https://console.neon.tech > seu projeto > Connection Details
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Chave secreta para assinar JWT (mínimo 32 caracteres aleatórios)
JWT_SECRET=sua-chave-secreta-muito-longa-e-aleatoria-aqui

# Código secreto para registrar conta de administrador
# Quem tiver este código pode virar admin — use algo forte
ADMIN_CODE=codigo-secreto-admin-2024
